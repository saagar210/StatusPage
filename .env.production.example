# PostgreSQL
POSTGRES_USER=statuspage
POSTGRES_PASSWORD=change-me
POSTGRES_DB=statuspage
DATABASE_URL=postgresql://statuspage:change-me@postgres:5432/statuspage

# Redis
REDIS_URL=redis://redis:6379

# Web auth
AUTH_SECRET=<generate-with-openssl-rand-base64-32>
AUTH_GITHUB_ID=<github-oauth-app-id>
AUTH_GITHUB_SECRET=<github-oauth-app-secret>
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# Web <-> API
INTERNAL_API_URL=http://api-server:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
STATUSPAGE_HOST=localhost

# API
API_HOST=0.0.0.0
API_PORT=4000
LOG_LEVEL=info
RUN_MIGRATIONS_ON_START=false
RUN_MIGRATIONS_ONLY=false
APP_BASE_URL=http://localhost
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=alerts@statuspage.local
EMAIL_DISPATCH_INTERVAL_SECS=3
EMAIL_DISPATCH_BATCH_SIZE=20
WEBHOOK_DISPATCH_INTERVAL_SECS=3
WEBHOOK_DISPATCH_BATCH_SIZE=10
WEBHOOK_TIMEOUT_SECS=10
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
INTERNAL_ADMIN_TOKEN=
DOWNGRADE_ENFORCEMENT_INTERVAL_SECS=60
# Managed beta billing:
# - Set all four values to enable customer upgrades and the Stripe portal
# - Leave blank if you are rehearsing only the self-hosted core path
# - INTERNAL_ADMIN_TOKEN protects the internal support/operator endpoints
# - DOWNGRADE_ENFORCEMENT_INTERVAL_SECS controls how often grace-period warnings and enforcement run

# Monitor
MAX_CONCURRENT_CHECKS=50
CONFIG_RELOAD_INTERVAL_SECS=60
HEALTHCHECK_FILE=/tmp/monitor-heartbeat
