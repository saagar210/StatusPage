# Database
POSTGRES_PORT=55432
DATABASE_URL=postgresql://statuspage:statuspage@localhost:55432/statuspage

# Redis (used by health checks and realtime scaffolding)
REDIS_PORT=56379
REDIS_URL=redis://localhost:56379

# Auth (Next.js)
AUTH_SECRET=<random-32-char-string>
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Rust API Server
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=alerts@statuspage.local
EMAIL_DISPATCH_INTERVAL_SECS=3
EMAIL_DISPATCH_BATCH_SIZE=20
WEBHOOK_DISPATCH_INTERVAL_SECS=3
WEBHOOK_DISPATCH_BATCH_SIZE=10
WEBHOOK_TIMEOUT_SECS=10
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
